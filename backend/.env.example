# === backend/.env.example ===
# 실제 값은 backend/.env 에만 둔다 (절대 커밋 금지 — repo .gitignore 가 .env 를 무시).
# 여기에는 "키 이름만" 나열한다 (값 비움). CLUSTER_PASSWORD 등 비밀은 절대 채워 커밋하지 말 것.

# --- LLM (Anthropic Claude) ---
CLAUDE_API_KEY=
# 선택: 모델 id override (미설정 시 코드 기본값 사용)
ANTHROPIC_MODEL=

# --- 앱 ---
APP_PORT=8000

# --- 클러스터 (SSH / SGE) — f4 실제 제출용 ---
# USE_SGE=1 이면 app/core/sge.py 가 실제 qsub 제출, 0 이면 목 스트림 폴백
USE_SGE=0
CLUSTER_HOST=
CLUSTER_PORT=22
CLUSTER_USER=
# 비밀: 절대 값 채워 커밋하지 말 것 (로그·응답·문서에도 노출 금지)
CLUSTER_PASSWORD=
CLUSTER_REMOTE_ROOT=
CLUSTER_QUEUE=
# -pe 에는 CLUSTER_PE 통째로, mpiexec 에는 -n CLUSTER_MPI_RANKS (랭크를 -pe 에 붙이지 말 것)
CLUSTER_PE=
CLUSTER_MPI_RANKS=

# --- CP2K (클러스터 실행 환경) ---
CP2K_ROOT=
CP2K_DATA_DIR=
CP2K_MPIEXEC=
CP2K_SETVARS=
# run.sh 가 source 할 클러스터 venv activate 경로 (be/05 SGE_TEMPLATE 필수; 없으면 qsub 잡 즉사)
CP2K_VENV=
